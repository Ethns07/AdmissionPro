{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and role information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["super_admin", "admin", "admission_officer", "student", "parent", "guest"] },
        "displayName": { "type": "string" },
        "instituteId": { "type": "string", "description": "ID of the institute this user belongs to" },
        "assignedPrograms": { "type": "array", "description": "List of program IDs assigned to an admission officer" },
        "theme": { "type": "string", "enum": ["light", "dark"] },
        "isApproved": { "type": "boolean", "description": "Whether the institutional member has been approved by a super admin" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Institute": {
      "title": "Institute",
      "description": "Educational institution profile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "adminId": { "type": "string", "description": "UID of the primary admin for this institute" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "isBanned": { "type": "boolean", "description": "Whether the institute is banned from the platform" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "adminId"]
    },
    "Category": {
      "title": "Program Category",
      "description": "Categories for educational programs",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "instituteId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "Program": {
      "title": "Program",
      "description": "Educational program details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string", "description": "Program category" },
        "instituteId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "brochureUrl": { "type": "string" },
        "feeStructure": { "type": "object" },
        "eligibilityRules": { "type": "array" },
        "meritFormula": { "type": "string" },
        "duration": { "type": "string", "description": "Program duration (e.g., 4 Years)" },
        "deadline": { "type": "string", "format": "date-time", "description": "Program-specific application deadline" },
        "isActive": { "type": "boolean" }
      },
      "required": ["name", "isActive", "duration", "instituteId"]
    },
    "Application": {
      "title": "Application",
      "description": "Student admission application",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentUid": { "type": "string" },
        "studentName": { "type": "string" },
        "studentEmail": { "type": "string", "format": "email" },
        "programId": { "type": "string" },
        "programName": { "type": "string" },
        "instituteId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "eligible", "not_eligible", "waitlist", "offer_extended", "enrolled"] },
        "formData": { "type": "object" },
        "documents": { "type": "array" },
        "paymentStatus": { "type": "string", "enum": ["pending", "paid"] },
        "paymentDetails": { "type": "object" },
        "meritScore": { "type": "number" },
        "isOffline": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["programId", "status", "instituteId"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Records of financial transactions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "applicationId": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string" },
        "receiptNumber": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string" }
      },
      "required": ["applicationId", "amount", "method"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/institutes/{instituteId}": {
      "schema": "Institute",
      "description": "Educational institutions"
    },
    "/programs/{programId}": {
      "schema": "Program",
      "description": "Available programs"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Program categories"
    },
    "/applications/{applicationId}": {
      "schema": "Application",
      "description": "Admission applications"
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Financial records"
    }
  }
}
